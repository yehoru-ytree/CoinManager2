POSTGRES_PASSWORD=

MONOBANK_TOKEN=
MONOBANK_ACCOUNT_ID=

GOOGLE_SHEET_ID=

# Master template spreadsheet — a separate Google Sheet you keep with only the template-tab
# structure (no real expense data). The service account must have read access to this sheet;
# on createHousehold the bot copies the template tab from here into the new user's destination.
TEMPLATE_SPREADSHEET_ID=
TEMPLATE_SHEET_TITLE=

TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# Dedicated Gmail ingest mailbox for Privat email-forwarding flow.
# Create coinmanager.ingest@gmail.com (or any address), enable 2FA, generate an app password.
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=
EMAIL_IMAP_PASSWORD=
EMAIL_IMAP_FOLDER=INBOX
EMAIL_IMAP_POLL_INTERVAL=PT1M
